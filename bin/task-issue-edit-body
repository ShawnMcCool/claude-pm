#!/usr/bin/env bash
# Set an issue's body. New body is read from stdin.
# Usage: task-issue-edit-body <number>
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "${SCRIPT_DIR}/lib.sh"
require_config

[ $# -ge 1 ] || die "usage: task-issue-edit-body <number>"
number="$1"

tmpfile=$(mktemp)
trap 'rm -f "$tmpfile"' EXIT
cat > "$tmpfile"

gh issue edit "$number" --repo "${OWNER}/${REPO}" --body "$(cat "$tmpfile")"
echo "Updated issue #${number} body."
