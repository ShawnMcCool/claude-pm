#!/usr/bin/env bash
# Print the board URL.
# Usage: task-board-url
# Output: URL text
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "${SCRIPT_DIR}/lib.sh"
require_config

if [ "$OWNER_TYPE" = "Organization" ]; then
  echo "https://github.com/orgs/${OWNER}/projects/${PROJECT_NUMBER}?layout=board"
else
  echo "https://github.com/users/${OWNER}/projects/${PROJECT_NUMBER}?layout=board"
fi
